{
  "manifest_version": 3,
  "name": "Kiwi Secure Relay",
  "version": "1.4.0",
  "description": "Secure OpenClaw relay by Kiwi Technology - connects to VPS relay server.",
  "permissions": ["tabs", "activeTab", "storage", "debugger"],
  "host_permissions": ["*://93.127.213.22/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
